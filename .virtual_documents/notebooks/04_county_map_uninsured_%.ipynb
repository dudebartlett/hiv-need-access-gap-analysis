import pandas as pd
import numpy as np
import plotly.express as px

# --- Load CDC tables ---
df_prev_raw = pd.read_csv("../data/raw/cdc_hiv_prevalence_county.csv")
df_supp_raw = pd.read_csv("../data/raw/cdc_hiv_viral_suppression_county.csv")

# --- Keep only real data rows (drop the "Date Printed..." style header rows) ---
# We keep rows where the FIPS field looks like a number.
df_prev_raw = df_prev_raw[df_prev_raw["FIPS"].notna()].copy()
df_supp_raw = df_supp_raw[df_supp_raw["FIPS"].notna()].copy()

# --- Standardize FIPS ---
df_prev_raw["fips"] = df_prev_raw["FIPS"].astype(int).astype(str).str.zfill(5)
df_supp_raw["fips"] = df_supp_raw["FIPS"].astype(int).astype(str).str.zfill(5)

# --- Pick the metric columns ---
# Prevalence file: use the "Rate per 100000" column
# Suppression file: use the "Percent" column
df_prev = df_prev_raw[["fips", "Geography", "Rate per 100000"]].rename(
    columns={"Geography": "county_name", "Rate per 100000": "hiv_prev_rate_per_100k"}
)

df_supp = df_supp_raw[["fips", "Percent"]].rename(
    columns={"Percent": "viral_suppression_pct"}
)

# Convert metrics to numeric (handles any weird strings)
df_prev["hiv_prev_rate_per_100k"] = pd.to_numeric(df_prev["hiv_prev_rate_per_100k"], errors="coerce")
df_supp["viral_suppression_pct"] = pd.to_numeric(df_supp["viral_suppression_pct"], errors="coerce")

print("Prev rows:", df_prev.shape[0], "| unique fips:", df_prev["fips"].nunique())
print("Supp rows:", df_supp.shape[0], "| unique fips:", df_supp["fips"].nunique())
print("Prev missing rate:", df_prev["hiv_prev_rate_per_100k"].isna().sum())
print("Supp missing pct:", df_supp["viral_suppression_pct"].isna().sum())

# --- Merge into your access table (must already exist: df_access with fips/uninsured_pct/poverty_pct/access_risk_score) ---
df_full = (
    df_access.merge(df_prev[["fips", "county_name", "hiv_prev_rate_per_100k"]], on="fips", how="left")
            .merge(df_supp[["fips", "viral_suppression_pct"]], on="fips", how="left")
)

print("Full merged shape:", df_full.shape)
print(df_full[["hiv_prev_rate_per_100k", "viral_suppression_pct"]].isna().sum())

# --- Build ranks and a gap score ---
# Need rank: higher HIV prevalence rate = higher need
df_full["need_rank"] = df_full["hiv_prev_rate_per_100k"].rank(pct=True)

# Access rank: you already built access_risk_score (higher = worse barriers)
df_full["access_rank"] = df_full["access_risk_score"].rank(pct=True)

# Gap score (simple + interpretable): high need AND high barriers => high score
df_full["gap_score"] = (df_full["need_rank"] + df_full["access_rank"]) / 2

# --- Map the gap score ---
fig_gap = px.choropleth(
    df_full.dropna(subset=["gap_score"]),
    geojson=counties,
    locations="fips",
    color="gap_score",
    scope="usa",
    color_continuous_scale="Reds",
    labels={"gap_score": "Need vs Access gap (0–1)"},
)

fig_gap.update_layout(
    title="Need vs Access Gap Score (HIV prevalence + access barriers)",
    margin={"r": 0, "t": 50, "l": 0, "b": 0},
)

fig_gap.show()

# --- Top 15 counties by gap score (with suppression shown) ---
top15_gap = df_full.sort_values("gap_score", ascending=False).head(15)[
    ["fips", "county_name", "hiv_prev_rate_per_100k", "uninsured_pct", "poverty_pct", "access_risk_score", "viral_suppression_pct", "gap_score"]
]

top15_gap


