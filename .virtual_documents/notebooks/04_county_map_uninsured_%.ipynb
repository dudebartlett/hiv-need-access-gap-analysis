# Show any column names that look like they might be FIPS/GEOID
def fips_candidates(cols):
    hits = []
    for c in cols:
        s = c.lower()
        if "fips" in s or "geoid" in s or s in ["geo", "geography", "county", "county_code", "countycode"]:
            hits.append(c)
    return hits

