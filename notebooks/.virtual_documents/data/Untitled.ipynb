


import pandas as pd

url = "https://raw.githubusercontent.com/plotly/datasets/master/fips-unemp-16.csv"
df_real = pd.read_csv(url, dtype={"fips": str})

df_real.head()


df_real.shape


import json

with open("../../data/raw/geo/geojson-counties-fips.json", "r") as f:
    counties = json.load(f)


import plotly.express as px

df_real["fips"] = df_real["fips"].astype(str).str.zfill(5)

fig = px.choropleth(
    df_real,
    geojson=counties,
    locations="fips",
    color="unemp",
    scope="usa",
    color_continuous_scale="Viridis",
    labels={"unemp": "Unemployment rate"},
)

fig.update_layout(
    title="County map (full US)",
    margin={"r":0,"t":50,"l":0,"b":0},
)

fig.show()
