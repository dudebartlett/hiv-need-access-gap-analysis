import pandas as pd

url = "https://raw.githubusercontent.com/plotly/datasets/master/fips-unemp-16.csv"
df_real = pd.read_csv(url, dtype={"fips": str})

df_real["fips"] = df_real["fips"].astype(str).str.zfill(5)
df_real.head()


import json

with open("../../data/raw/geo/geojson-counties-fips.json", "r") as f:
    counties = json.load(f)


df_real.head()
df_real.info()
df_real.isna().sum()
df_real["unemp"].describe()


# How many rows of county data do we have?
df_real.shape


# How many unique county FIPS codes are in the data?
df_real["fips"].nunique()


# How many unique county FIPS codes are in the data?
df_real["fips"].nunique()


df_real["unemp"].describe()


fig = px.choropleth(
    df_real,
    geojson=counties,
    locations="fips",
    color="unemp",
    scope="usa",
    color_continuous_scale="Viridis",
    labels={"unemp": "Unemployment rate"},
)
fig.update_layout(margin={"r":0,"t":40,"l":0,"b":0})
fig.show()


